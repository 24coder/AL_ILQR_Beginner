{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "CMake: Build All (Debug)",
            "type": "shell",
            "command": "cmake -S ${workspaceFolder}/al-ilqr-starter -B ${workspaceFolder}/al-ilqr-starter/build -DCMAKE_BUILD_TYPE=Debug && cmake --build ${workspaceFolder}/al-ilqr-starter/build -j4",
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            },
            "problemMatcher": ["$gcc"]
        },
        {
            "label": "Build: phase9_autodrive_visualization_demo (Debug)",
            "type": "shell",
            "command": "cmake -S ${workspaceFolder}/al-ilqr-starter -B ${workspaceFolder}/al-ilqr-starter/build -DCMAKE_BUILD_TYPE=Debug && cmake --build ${workspaceFolder}/al-ilqr-starter/build --target phase9_autodrive_visualization_demo -j4",
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            },
            "problemMatcher": ["$gcc"]
        },
        {
